@echo off
chcp 65001 >nul 2>&1
title PaintShot - Installatie
echo.
echo  ========================================
echo       PaintShot - Installatie
echo  ========================================
echo.

REM --- Stap 1: Python controleren ---
echo  [1/5] Python controleren...
python --version >nul 2>&1
if errorlevel 1 (
    echo.
    echo  FOUT: Python is niet geinstalleerd!
    echo  Download Python via: https://www.python.org/downloads/
    echo  Zorg dat "Add Python to PATH" is aangevinkt.
    echo.
    pause
    exit /b 1
)
echo        Python gevonden.

REM --- Stap 2: Pillow installeren ---
echo  [2/5] Pillow installeren...
pip install pillow --quiet >nul 2>&1
echo        Pillow geinstalleerd.

REM --- Stap 3: Map aanmaken ---
